---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ContactBlock from "../../components/ContactBlock.astro";
import MetricItem from "../../components/MetricItem.astro";
import { localPath } from "../../utils/links";

export async function getStaticPaths() {
  const cases = await getCollection("cases");

  return cases.map((caseEntry) => {
    const slug = (caseEntry as any).slug ?? caseEntry.id.replace(/\.md$/, "");
    return {
      params: { slug },
      props: { caseEntry }
    };
  });
}

const { caseEntry } = Astro.props;
const { Content } = await render(caseEntry);
---

<BaseLayout
  title={`${caseEntry.data.company} - кейс Кирилла Панфилова`}
  description={caseEntry.data.summary}
>
  <Header />

  <main>
    <section class="case-hero">
      <div class="container">
        <a class="back-link" href={localPath("/#cases")}>Назад к кейсам</a>
        <div class="case-hero-grid">
          <div>
            <span class="eyebrow">{caseEntry.data.context}</span>
            <h1>{caseEntry.data.title}</h1>
            <p>{caseEntry.data.challenge}</p>
            <div class="tag-list">
              {caseEntry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <aside class="case-metrics card">
            {caseEntry.data.metrics.map((metric) => <MetricItem {...metric} />)}
          </aside>
        </div>
      </div>
    </section>

    <section class="section case-detail">
      <div class="container detail-grid">
        <aside class="detail-aside">
          <span class="eyebrow">Что делал</span>
          <ul>
            {caseEntry.data.work.map((item) => <li>{item}</li>)}
          </ul>
        </aside>
        <article class="detail-content">
          <h2>Результат</h2>
          <p class="result">{caseEntry.data.result}</p>
          <div class="content-body">
            <Content />
          </div>
        </article>
      </div>
    </section>

    <ContactBlock />
  </main>

  <Footer />
</BaseLayout>

<style>
  .case-hero {
    padding: 72px 0 86px;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 34px;
    color: var(--muted);
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .case-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: 40px;
    align-items: end;
  }

  h1 {
    max-width: 860px;
    margin: 16px 0 0;
    font-size: clamp(46px, 7vw, 86px);
    line-height: 0.94;
    letter-spacing: -0.065em;
  }

  .case-hero p {
    max-width: 760px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 20px;
  }

  .case-hero .tag-list {
    margin-top: 28px;
  }

  .case-metrics {
    display: grid;
    gap: 28px;
    padding: 28px;
  }

  .case-detail {
    background: white;
    border-top: 1px solid var(--line);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 360px minmax(0, 1fr);
    gap: 52px;
  }

  .detail-aside {
    position: sticky;
    top: 104px;
    align-self: start;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface-soft);
    padding: 26px;
  }

  .detail-aside ul {
    display: grid;
    gap: 16px;
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  .detail-aside li {
    border-top: 1px solid var(--line);
    padding-top: 16px;
    color: #2e3845;
  }

  .detail-content {
    max-width: 780px;
  }

  .detail-content h2 {
    margin: 0;
    font-size: 42px;
    letter-spacing: -0.05em;
  }

  .result {
    margin: 18px 0 34px;
    color: var(--ink);
    font-size: 22px;
    line-height: 1.4;
  }

  .content-body {
    color: var(--muted);
    font-size: 19px;
  }

  .content-body :global(p) {
    margin: 0 0 20px;
  }

  @media (max-width: 880px) {
    .case-hero-grid,
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .detail-aside {
      position: static;
    }
  }
</style>
